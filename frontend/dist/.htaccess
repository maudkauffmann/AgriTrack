# Désactiver l'affichage des dossiers pour la sécurité
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. ROUTAGE API (SYMFONY)
    # On intercepte tout ce qui commence par /api
    # Comme la racine est www/frontend/dist, on remonte de 2 niveaux :
    # (dist -> frontend -> www) puis on descend dans backend/public
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^api/(.*)$ ../../backend/public/index.php [QSA,L]

    # 2. ROUTAGE FRONTEND (REACT)
    # Si l'utilisateur demande une page qui n'est pas un fichier réel (.jpg, .js, .css)
    # On renvoie tout sur index.html pour que React Router prenne le relais.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>